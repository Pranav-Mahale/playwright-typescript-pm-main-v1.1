{
  "name": "playwright-typescript-pm-main-v1.1",
  "version": "1.0.0",
  "description": "Enterprise-friendly Playwright TypeScript automation framework with UI, API, contract, database, performance, reporting, and observability examples.",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test tests/smoke",
    "test:regression": "playwright test tests/regression",
    "test:e2e": "playwright test tests/e2e",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:contract": "playwright test tests/contract",
    "test:database": "playwright test tests/database",
    "test:performance": "playwright test tests/performance",
    "test:headed": "playwright test --headed",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "report:html": "playwright show-report reports/html-report",
    "report:allure": "allure generate reports/allure-results --clean -o reports/allure-report",
    "report:summary": "ts-node scripts/generate-final-report.ts",
    "heal": "ts-node ai/self-healing/healer.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "allure-commandline": "^2.30.0",
    "allure-playwright": "^3.0.9",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2"
  }
}
